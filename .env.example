# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DB=video_collector
PG_USER=postgres
PG_PASSWORD=postgres

# Redis (for rq task queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Aliyun OSS (你的 bucket: storage1111, 杭州)
OSS_ACCESS_KEY_ID=your_ram_access_key_id
OSS_ACCESS_KEY_SECRET=your_ram_access_key_secret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=storage1111
OSS_VIDEO_PREFIX=videos/raw
OSS_COVER_PREFIX=covers/raw

# YouTube Data API v3（如需采 YouTube 才需要）
YOUTUBE_API_KEY=

# Worker
WORKER_TTL=600
DOWNLOAD_TIMEOUT=300
DOWNLOAD_RETRIES=3
MAX_CONCURRENT_DOWNLOADS=3
# 临时性失败的最大重试次数(超过即视为永久失败,cron 不再拉起)
MAX_DOWNLOAD_ATTEMPTS=5
# cron 重试冷却(小时):最近一次尝试至少 N 小时前才会被重新入队
RETRY_COOLDOWN_HOURS=1
